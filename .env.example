# Production values to set in the Cloudflare Pages dashboard.
# Copy this file to .env for local development.

# Google Tag Manager container ID (public — appears in page HTML at runtime).
PUBLIC_GTM_ID=GTM-K5RK9QMJ

# Web3Forms access key — register per-domain at https://web3forms.com.
# Omit during local dev to avoid sending real form submissions.
PUBLIC_WEB3FORMS_KEY=

# Optional override for the site's canonical origin (defaults to https://tenebris.com.ua).
PUBLIC_SITE_URL=
