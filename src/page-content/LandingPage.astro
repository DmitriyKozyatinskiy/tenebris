---
import Layout from '../layouts/Layout.astro';
import Hero from './sections/Hero.astro';
import Proof from './sections/Proof.astro';
import Systems from './sections/Systems.astro';
import Advantages from './sections/Advantages.astro';
import Training from './sections/Training.astro';
import Press from './sections/Press.astro';
import Careers from './sections/Careers.astro';
import Contact from './sections/Contact.astro';
import { toLocale } from '../i18n/utils';
import { homeTranslations } from '../i18n/translations';
import { buildPressItemList } from '../utils/schema';

interface Props {
  locale?: string;
}
const locale = toLocale(Astro.props.locale);
const t = homeTranslations[locale];
---

<Layout
  title={t.meta.title}
  description={t.meta.description}
  locale={locale}
  schemas={[buildPressItemList(locale)]}
>
  <Hero locale={locale} />
  <Proof locale={locale} />
  <Systems locale={locale} />
  <Advantages locale={locale} />
  <Training locale={locale} />
  <Press locale={locale} />
  <Careers locale={locale} />
  <Contact locale={locale} />
</Layout>
