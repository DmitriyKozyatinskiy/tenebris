---
import { Icon } from 'astro-icon/components';
import Container from '../../components/astro/Container.astro';
import Section from '../../components/astro/Section.astro';
import SectionHeader from '../../components/astro/SectionHeader.astro';
import { localizeUrl } from '../../i18n/utils';
import { home as homeEn } from '../../i18n/en/pages/home';
import { home as homeUk } from '../../i18n/uk/pages/home';
import type { Locale } from '../../i18n/types';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = locale === 'uk' ? homeUk : homeEn;
---

<Section id="training">
  <Container>
    <SectionHeader eyebrow={t.training.eyebrow} heading={t.training.heading} />
    <div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:gap-16">
      <div data-reveal>
        <p class="max-w-xl text-base leading-relaxed text-[--color-fg] sm:text-lg">
          {t.training.paragraph1}
        </p>
        <p class="mt-4 max-w-xl text-base leading-relaxed text-[--color-fg-muted] sm:text-lg">
          {t.training.paragraph2}
        </p>
        <ul class="mt-8 space-y-3">
          {
            t.training.bullets.map((b) => (
              <li class="flex items-start gap-3">
                <span class="mt-[8px] h-px w-5 shrink-0 bg-[--color-accent]" aria-hidden="true" />
                <span class="text-sm text-[--color-fg] sm:text-base">{b}</span>
              </li>
            ))
          }
        </ul>
        <a
          href={`${localizeUrl('/#contact', locale)}?subject=training`}
          class="btn-primary mt-10"
        >
          {t.training.cta}
          <Icon name="lucide:arrow-right" class="h-4 w-4" />
        </a>
      </div>
      <div data-reveal>
        <div class="relative">
          <div
            class="pointer-events-none absolute -top-2 -left-2 h-6 w-6 border-t border-l border-[--color-accent]"
            aria-hidden="true"
          >
          </div>
          <div
            class="pointer-events-none absolute -right-2 -bottom-2 h-6 w-6 border-r border-b border-[--color-accent]"
            aria-hidden="true"
          >
          </div>
          <picture>
            <source
              type="image/avif"
              srcset="/photos/420480_12_new_960x380_0-800.avif 800w, /photos/420480_12_new_960x380_0-1600.avif 1600w"
              sizes="(min-width: 1024px) 40vw, 100vw"
            />
            <img
              src="/photos/420480_12_new_960x380_0-1600.webp"
              alt={t.training.imgAlt}
              width="1600"
              height="633"
              loading="lazy"
              decoding="async"
              class="block h-auto w-full border border-[--color-border] bg-[--color-bg-raised] object-cover"
            />
          </picture>
        </div>
      </div>
    </div>
  </Container>
</Section>
