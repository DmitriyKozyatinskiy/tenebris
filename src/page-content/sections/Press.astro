---
import { Icon } from 'astro-icon/components';
import Container from '../../components/astro/Container.astro';
import Section from '../../components/astro/Section.astro';
import SectionHeader from '../../components/astro/SectionHeader.astro';
import { press } from '../../data/press';
import { homeTranslations, pressTranslations } from '../../i18n/translations';
import type { Locale } from '../../i18n/types';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = homeTranslations[locale];
const p = pressTranslations[locale];

function formatDate(iso: string, loc: Locale) {
  try {
    return new Date(iso).toLocaleDateString(loc === 'uk' ? 'uk-UA' : 'en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    });
  } catch {
    return iso;
  }
}
---

<Section id="press">
  <Container>
    <SectionHeader eyebrow={t.press.eyebrow} heading={t.press.heading} />
    <div class="grid gap-6 md:grid-cols-2">
      {
        press.map((item) => (
          <a
            href={item.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group block border border-[--color-border] bg-[--color-bg-raised] p-0 transition-colors hover:border-[--color-accent]"
            data-reveal
          >
            <div class="relative aspect-[16/9] w-full overflow-hidden bg-[--color-bg]">
              <img
                src={item.thumbnail}
                alt={p.pullquotes[item.id]}
                width="1600"
                height="900"
                loading="lazy"
                decoding="async"
                class="absolute inset-0 h-full w-full object-cover opacity-80 transition-opacity group-hover:opacity-100"
              />
            </div>
            <div class="space-y-3 p-6 sm:p-8">
              <div class="flex items-center justify-between font-mono text-[11px] tracking-[0.2em] text-[--color-fg-muted] uppercase">
                <span>{item.outlet}</span>
                <span>{formatDate(item.dateISO, locale)}</span>
              </div>
              <p class="font-display text-lg leading-snug text-[--color-fg] sm:text-xl">
                “{p.pullquotes[item.id]}”
              </p>
              <div class="flex items-center gap-2 pt-1 font-mono text-[11px] tracking-[0.2em] text-[--color-accent] uppercase">
                {t.press.readMore}
                <Icon name="lucide:arrow-up-right" class="h-3.5 w-3.5" />
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </Container>
</Section>
