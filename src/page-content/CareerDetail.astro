---
import { Icon } from 'astro-icon/components';
import Layout from '../layouts/Layout.astro';
import Container from '../components/astro/Container.astro';
import Section from '../components/astro/Section.astro';
import Breadcrumb from '../components/astro/Breadcrumb.astro';
import Eyebrow from '../components/astro/Eyebrow.astro';
import { getRole } from '../data/roles';
import { careerDetailTranslations, roleTranslations } from '../i18n/translations';
import { commonTranslations } from '../i18n/common';
import { localizeUrl, toLocale } from '../i18n/utils';
import { buildBreadcrumb, buildJobPosting } from '../utils/schema';

interface Props {
  locale?: string;
  slug: string;
}
const { slug } = Astro.props;
const locale = toLocale(Astro.props.locale);
const role = getRole(slug);
if (!role) {
  return Astro.redirect('/404/');
}
const rs = roleTranslations[locale];
const detail = careerDetailTranslations[locale];
const common = commonTranslations[locale];
const r = rs[role.slug];
const meta = detail.meta(r.title);

const crumbs = [
  { name: common.breadcrumbs.home, path: localizeUrl('/', locale) },
  { name: common.breadcrumbs.careers, path: localizeUrl('/careers/', locale) },
  { name: r.title, path: localizeUrl(`/careers/${role.slug}/`, locale) },
];
const schemas = [buildBreadcrumb(crumbs, locale), buildJobPosting(role, locale)];
---

<Layout
  title={meta.title}
  description={meta.description}
  locale={locale}
  schemas={schemas}
>
  <Section border={false}>
    <Container>
      <Breadcrumb
        className="mb-12"
        items={[
          { label: common.breadcrumbs.home, href: localizeUrl('/', locale) },
          { label: common.breadcrumbs.careers, href: localizeUrl('/careers/', locale) },
          { label: r.title },
        ]}
      />

      <div class="max-w-3xl" data-reveal>
        <Eyebrow accent>{r.teamLabel}</Eyebrow>
        <h1
          class="font-display mt-3 text-4xl leading-tight font-semibold tracking-tight sm:text-5xl lg:text-6xl"
        >
          {r.title}
        </h1>
        <p class="mt-4 font-mono text-xs tracking-[0.2em] text-[--color-fg-muted] uppercase">
          {role.baseLocation} · {role.employmentType.replace('_', ' ')}
        </p>
      </div>

      <div class="mt-16 grid gap-16 lg:grid-cols-[2fr_1fr]">
        <div class="space-y-12">
          <div data-reveal>
            <h2 class="font-mono text-xs tracking-[0.2em] text-[--color-accent] uppercase">
              {detail.missionHeading}
            </h2>
            <p class="font-display mt-4 text-xl leading-relaxed text-[--color-fg] sm:text-2xl">
              {r.mission}
            </p>
          </div>

          <div data-reveal>
            <h2 class="font-mono text-xs tracking-[0.2em] text-[--color-accent] uppercase">
              {detail.responsibilitiesHeading}
            </h2>
            <ul class="mt-4 space-y-3">
              {
                r.responsibilities.map((item) => (
                  <li class="flex items-start gap-3">
                    <span
                      class="mt-[8px] h-px w-5 shrink-0 bg-[--color-accent]"
                      aria-hidden="true"
                    />
                    <span class="text-sm text-[--color-fg] sm:text-base">{item}</span>
                  </li>
                ))
              }
            </ul>
          </div>

          <div data-reveal>
            <h2 class="font-mono text-xs tracking-[0.2em] text-[--color-accent] uppercase">
              {detail.requirementsHeading}
            </h2>
            <ul class="mt-4 space-y-3">
              {
                r.requirements.map((item) => (
                  <li class="flex items-start gap-3">
                    <span
                      class="mt-[8px] h-px w-5 shrink-0 bg-[--color-accent]"
                      aria-hidden="true"
                    />
                    <span class="text-sm text-[--color-fg] sm:text-base">{item}</span>
                  </li>
                ))
              }
            </ul>
          </div>

          {
            r.niceToHaves.length > 0 && (
              <div data-reveal>
                <h2 class="font-mono text-xs tracking-[0.2em] text-[--color-accent] uppercase">
                  {detail.niceToHavesHeading}
                </h2>
                <ul class="mt-4 space-y-3">
                  {r.niceToHaves.map((item) => (
                    <li class="flex items-start gap-3">
                      <span
                        class="mt-[8px] h-px w-5 shrink-0 bg-[--color-fg-dim]"
                        aria-hidden="true"
                      />
                      <span class="text-sm text-[--color-fg-muted] sm:text-base">{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )
          }
        </div>

        <aside class="space-y-6 lg:sticky lg:top-20 lg:self-start" data-reveal>
          <div class="border border-[--color-border] bg-[--color-bg-raised] p-6 sm:p-8">
            <h2 class="font-mono text-xs tracking-[0.2em] text-[--color-accent] uppercase">
              {detail.applyHeading}
            </h2>
            <p class="mt-4 text-sm leading-relaxed text-[--color-fg-muted] sm:text-base">
              {detail.applyParagraph}
            </p>
            <a
              href={`${localizeUrl('/', locale)}?subject=${role.slug}#contact`}
              class="btn-primary mt-6"
            >
              {detail.applyCta}
              <Icon name="lucide:arrow-right" class="h-4 w-4" />
            </a>
          </div>

          <dl class="space-y-4 border-t border-[--color-border] pt-6">
            <div>
              <dt class="font-mono text-[11px] tracking-[0.2em] text-[--color-fg-muted] uppercase">
                {r.locationLabel}
              </dt>
              <dd class="mt-1 font-mono text-sm text-[--color-fg]">{role.baseLocation}</dd>
            </div>
            <div>
              <dt class="font-mono text-[11px] tracking-[0.2em] text-[--color-fg-muted] uppercase">
                {r.employmentLabel}
              </dt>
              <dd class="mt-1 font-mono text-sm text-[--color-fg]">
                {role.employmentType.replace('_', ' ')}
              </dd>
            </div>
          </dl>
        </aside>
      </div>
    </Container>
  </Section>
</Layout>
