---
interface Props {
  id?: string;
  className?: string;
  border?: boolean;
}
const { id, className = '', border = true } = Astro.props;
---

<section
  id={id}
  class:list={[
    'relative py-20 sm:py-24 lg:py-32',
    border && 'border-t border-[--color-border]',
    className,
  ]}
>
  <slot />
</section>
