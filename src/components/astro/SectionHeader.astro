---
import Eyebrow from './Eyebrow.astro';

interface Props {
  eyebrow: string;
  heading: string;
  intro?: string;
  className?: string;
}
const { eyebrow, heading, intro, className = '' } = Astro.props;
---

<div class={`mb-12 sm:mb-16 ${className}`} data-reveal>
  <Eyebrow accent>{eyebrow}</Eyebrow>
  <h2
    class="font-display mt-3 text-3xl leading-tight font-semibold tracking-tight text-[--color-fg] sm:text-4xl lg:text-5xl"
  >
    {heading}
  </h2>
  {intro && <p class="mt-6 max-w-2xl text-base text-[--color-fg-muted] sm:text-lg">{intro}</p>}
</div>
