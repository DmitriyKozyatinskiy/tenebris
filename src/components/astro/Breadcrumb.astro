---
import { Icon } from 'astro-icon/components';

interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
  className?: string;
}
const { items, className = '' } = Astro.props;
---

<nav aria-label="Breadcrumb" class={className}>
  <ol
    class="flex flex-wrap items-center gap-2 font-mono text-[11px] tracking-[0.2em] text-[--color-fg-muted] uppercase"
  >
    {
      items.map((item, i) => (
        <li class="flex items-center gap-2">
          {item.href ? (
            <a href={item.href} class="transition-colors hover:text-[--color-accent]">
              {item.label}
            </a>
          ) : (
            <span class="text-[--color-fg]">{item.label}</span>
          )}
          {i < items.length - 1 && (
            <Icon name="lucide:chevron-right" class="h-3.5 w-3.5 text-[--color-fg-dim]" />
          )}
        </li>
      ))
    }
  </ol>
</nav>
